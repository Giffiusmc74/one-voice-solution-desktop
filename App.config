<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
	<appSettings>
		<add key="ValidateLicenseURL" value="https://onevoiceapp-wpzvhh8c.manus.space/api/license/validate" />
		<add key="HeartbeatURL" value="https://onevoiceapp-wpzvhh8c.manus.space/api/license/heartbeat" />
		<add key="HeartbeatIntervalMinutes" value="10" />
		<add key="AppVersion" value="7.87" />
		<!-- Pre-keyed installer: set this to a license key so agents never see the key entry screen.
		     Leave empty for standard single-user installs. Call centers set this to their purchased key. -->
		<add key="PreloadedLicenseKey" value="" />
	</appSettings>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>